<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="src/Prayer/Program.cs" />
    <Compile Remove="src/Prayer/obj/**" />
    <Compile Remove="src/Prayer/bin/**" />
    <Compile Remove="src/Prayer.Contracts/**" />
    <EmbeddedResource Remove="src/Prayer/README.md" />
    <EmbeddedResource Remove="src/Prayer/obj/**" />
    <EmbeddedResource Remove="src/Prayer/bin/**" />
    <EmbeddedResource Remove="src/Prayer.Contracts/**" />
